# ── MySQL ─────────────────────────────────────────────────────────────────────

# Superusuário root — use apenas via scripts, nunca nos projetos
MYSQL_ROOT_PASSWORD=mysql_root_local

# Porta exposta no host
MYSQL_PORT=3306

# Serviços de aplicação: user||password||database  (múltiplos separados por ;)
# Para adicionar: inclua aqui e rode: docker compose exec mysql /scripts/mysql-setup.sh
MYSQL_APP_SERVICES=fut_scrapy||fut_scrapy||fut_scrapy
