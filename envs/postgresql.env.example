# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Superusuário admin — use apenas via scripts, nunca nos projetos
PG_ADMIN_USER=localservices_admin
PG_ADMIN_PASSWORD=localservices_admin

# Banco compartilhado onde cada serviço terá seu próprio schema isolado
PG_APP_DB=localservices

# Usuário dedicado ao Temporal (recebe CREATEDB — não inclua em PG_APP_SERVICES)
PG_TEMPORAL_USER=temporal
PG_TEMPORAL_PASSWORD=temporal

# Serviços de aplicação: user||password||schema  (múltiplos separados por ;)
# Schema é opcional — se omitido, usa o nome do usuário
# Para adicionar: inclua aqui e rode: docker compose exec postgresql /scripts/pg-setup.sh
PG_APP_SERVICES=edutask||edutask||edutask
